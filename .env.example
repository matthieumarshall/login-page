# Copy this file to .env before starting the dev server.
# `just sync` does this automatically on first run.
#
# The dev server loads .env automatically via `uvicorn --env-file .env`.
# Never commit .env — it is listed in .gitignore.

# Signs session cookies.
# Generate a value with: python -c "import secrets; print(secrets.token_hex(32))"
# Leaving blank in development is fine — an insecure placeholder key is used.
SECRET_KEY=

# Set to true on a live server to enforce HTTPS-only cookies and HSTS.
PRODUCTION=false

# Override the DuckDB database path (default: data/app.duckdb).
# DATABASE_URL=data/app.duckdb
